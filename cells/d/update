#!/usr/bin/env bash

# shellcheck shell=bash

set -euo pipefail
shopt -s inherit_errexit 2> /dev/null || true

SELF_PATH=$(realpath "${BASH_SOURCE[0]}") SELF="${SELF_PATH##*/}"
INDEX_HEADER="# LINA_DISTRO_INDEX v1"

usage() {
    cat << EOF
用法: ${LINA_PREFIX:-$SELF} [操作]

获取发行版数据（更新远程源索引）。

操作:
  (无参数)    从所有已配置的源更新索引
  -h, --help  显示此帮助信息
EOF
    exit "${1:-0}"
}

# 将源 URL 解析为可用于获取文件的基础 URL
# https://github.com/owner/repo -> https://raw.githubusercontent.com/owner/repo/HEAD
resolve_base_url() {
    local url="$1"
    if [[ $url =~ ^https://github\.com/([^/]+)/([^/]+) ]]; then
        local owner="${BASH_REMATCH[1]}" repo="${BASH_REMATCH[2]}"
        repo="${repo%.git}"
        printf 'https://raw.githubusercontent.com/%s/%s/HEAD' "$owner" "$repo"
    else
        printf '%s' "$url"
    fi
}

# 根据 URL 获取 INDEX 内容
fetch_index() {
    local url="$1"
    case "$url" in
        file://*)
            local path="${url#file://}"
            [[ -f $path ]] || return 1
            cat "$path"
            ;;
        http://* | https://* | ftp://*)
            curl -fsSL --connect-timeout 10 --max-time 30 "$url" 2> /dev/null || return 1
            ;;
        *)
            return 1
            ;;
    esac
}

# 解析一行 INDEX 数据，输出 PATH、NAME、ARCHS、VERSIONS、DESC
# 格式: <path>,<archs>,<versions>  # <description>
parse_index_line() {
    local line="$1"
    local data_part desc=""

    if [[ $line == *"  # "* ]]; then
        data_part="${line%%  # *}"
        desc="${line##*  # }"
    elif [[ $line == *"#"* ]]; then
        data_part="${line%%#*}"
        desc="${line#*#}"
        desc="${desc## }"
    else
        data_part="$line"
    fi

    data_part="${data_part#"${data_part%%[![:space:]]*}"}"
    data_part="${data_part%"${data_part##*[![:space:]]}"}"
    [[ -z $data_part ]] && return 1

    local path="${data_part%%,*}"
    local rest="${data_part#*,}"
    local archs="${rest%%,*}"
    local versions="${rest#*,}"

    [[ -n $path && -n $archs && -n $versions ]] || return 1

    local name="${path##*/}"
    name="${name%.sh}"

    printf 'PATH_VAL=%q\nNAME=%q\nARCHS=%q\nVERSIONS=%q\nDESC_VAL=%q\n' \
        "$path" "$name" "$archs" "$versions" "$desc"
    return 0
}

main() {
    [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && usage

    local REPOS_FILE="${LINA_CONFIG_DIR:?错误: 缺少 LINA_CONFIG_DIR 环境变量}/repos"
    local CACHE_DIR="${LINA_CONFIG_DIR:?}/distro-cache"

    mkdir -p "$LINA_CONFIG_DIR" "$CACHE_DIR"
    [[ -e $REPOS_FILE ]] || touch "$REPOS_FILE"

    local command="${1:-}"
    case "$command" in
        "") ;;
        *)
            usage 1
            ;;
    esac

    [[ ! -s $REPOS_FILE ]] && {
        printf "错误: 没有配置任何源。请先添加源。\n" >&2
        exit 1
    }

    local repo_url configured=0 succeeded=0 failed=0 update_count=0 skipped=0

    # 清空旧缓存，全新重建
    rm -f "$CACHE_DIR"/*

    while IFS= read -r repo_url; do
        [[ -z $repo_url ]] && continue
        [[ $repo_url == "#"* ]] && continue
        ((++configured))

        local base_url
        base_url=$(resolve_base_url "$repo_url")
        printf "获取: %s\n" "$repo_url"

        local index_content
        index_content=$(fetch_index "${base_url}/INDEX") || {
            printf "  警告: 无法获取 INDEX，跳过此源\n" >&2
            ((++failed))
            continue
        }

        # 验证格式标识
        local first_line
        first_line=$(head -n 1 <<< "$index_content")
        if [[ $first_line != "$INDEX_HEADER" ]]; then
            if [[ $first_line == "# LINA_DISTRO_INDEX v"* ]]; then
                printf "  警告: INDEX 版本不兼容（预期 %s，实际 %s），跳过此源\n" \
                    "$INDEX_HEADER" "$first_line" >&2
            else
                printf "  警告: INDEX 格式不正确（缺少版本标识），跳过此源\n" >&2
            fi
            ((++failed))
            continue
        fi

        ((++succeeded))

        local line_num=0 parsed=0 entries=0 line
        while IFS= read -r line; do
            ((++line_num))
            [[ $line_num -eq 1 ]] && continue
            [[ -z $line ]] && continue
            [[ $line == "#"* ]] && continue

            local PATH_VAL NAME ARCHS VERSIONS DESC_VAL
            eval "$(parse_index_line "$line")" || continue
            ((++parsed))

            local arch
            for arch in $ARCHS; do
                local content_hash
                content_hash=$(printf 'NAME=%s\nARCH=%s\nVERSIONS=%s\nDESC=%s\n' \
                    "$NAME" "$arch" "$VERSIONS" "$DESC_VAL" | md5sum)
                content_hash="${content_hash%% *}"
                content_hash="${content_hash:0:8}"

                local cache_file="$CACHE_DIR/${NAME}.${arch}.${content_hash}"
                if [[ -f $cache_file ]]; then
                    ((++skipped))
                    continue
                fi

                ((++entries))

                {
                    printf 'SOURCE=%s\n' "$base_url"
                    printf 'PATH=%s\n' "$PATH_VAL"
                    printf 'NAME=%s\n' "$NAME"
                    printf 'ARCH=%s\n' "$arch"
                    printf 'VERSIONS=%s\n' "$VERSIONS"
                    printf 'DESC=%s\n' "$DESC_VAL"
                } > "$cache_file"

                printf "  %s (%s) %s\n" "$NAME" "$arch" "$VERSIONS"
            done
        done <<< "$index_content"

        if ((parsed == 0)); then
            printf "  警告: INDEX 中没有有效条目\n" >&2
        fi
        ((update_count += entries))
    done < "$REPOS_FILE"

    ((configured == 0)) && {
        printf "没有有效的源配置。\n" >&2
        exit 1
    }

    printf "\n更新完成: %d 个源, 共 %d 个发行版条目" "$succeeded" "$update_count"
    ((skipped > 0)) && printf ", %d 个重复跳过" "$skipped"
    ((failed > 0)) && printf "（%d 个源失败）" "$failed"
    printf "\n"

    if ((update_count == 0)); then
        exit 2
    fi
}

main "$@"
