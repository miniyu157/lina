#!/usr/bin/env bash

# shellcheck shell=bash

set -euo pipefail
shopt -s inherit_errexit 2> /dev/null || true

SELF_PATH=$(realpath "${BASH_SOURCE[0]}") SELF="${SELF_PATH##*/}"
INDEX_HEADER="# LINA_DISTRO_INDEX v2"

usage() {
    cat << EOF
用法: ${LINA_CMD:-$SELF} [操作]

获取发行版数据（更新远程源索引）。

操作:
  (无参数)    从所有已配置的源更新索引
  -h, --help  显示此帮助信息
EOF
    exit "${1:-0}"
}

# 将源 URL 解析为可用于获取文件的基础 URL
# https://github.com/owner/repo -> https://raw.githubusercontent.com/owner/repo/HEAD
resolve_base_url() {
    local url="$1"
    if [[ $url =~ ^https://github\.com/([^/]+)/([^/]+) ]]; then
        local owner="${BASH_REMATCH[1]}" repo="${BASH_REMATCH[2]}"
        repo="${repo%.git}"
        printf 'https://raw.githubusercontent.com/%s/%s/HEAD' "$owner" "$repo"
    else
        printf '%s' "$url"
    fi
}

# 根据 URL 获取 INDEX 内容
fetch_index() {
    local url="$1"
    case "$url" in
        file://*)
            local path="${url#file://}"
            [[ -f $path ]] || return 1
            cat "$path"
            ;;
        http://* | https://* | ftp://*)
            curl -fsSL --connect-timeout 10 --max-time 30 "$url" 2> /dev/null || return 1
            ;;
        *)
            return 1
            ;;
    esac
}

check_version() {
    [[ ${1:-} == "$INDEX_HEADER" ]]
}

main() {
    [[ ${1:-} == "-h" || ${1:-} == "--help" ]] && usage

    local REPOS_FILE="${LINA_CONFIG_DIR:?错误: 缺少 LINA_CONFIG_DIR 环境变量}/repos"
    local DB_FILE="${LINA_CONFIG_DIR:?}/local_index.tsv"
    mkdir -p "$LINA_CONFIG_DIR"
    [[ -e $REPOS_FILE ]] || touch "$REPOS_FILE"
    [[ -e $DB_FILE ]] || touch "$DB_FILE"

    local command="${1:-}"
    case "$command" in
        "") ;;
        *)
            usage 1
            ;;
    esac

    [[ ! -s $REPOS_FILE ]] && {
        printf "错误: 没有配置任何源。请先添加源。\n" >&2
        exit 1
    }

    local -A seen=()
    local base_url index_url index_content sh_url
    local hash path name archs versions desc

    while IFS= read -r repo_url; do
        [[ -z $repo_url ]] && continue

        base_url=$(resolve_base_url "$repo_url")
        index_url="${base_url}/INDEX"

        index_content=$(fetch_index "$index_url") || {
            printf "警告: 无法获取索引 '%s'\n" "$index_url" >&2
            continue
        }

        check_version "$(head -n1 <<< "$index_content")" || {
            printf "警告: 索引 '%s' 版本不匹配\n" "$index_url" >&2
            continue
        }

        while IFS=$'\t' read -r hash path name archs versions desc; do
            [[ -z $hash || $hash == \#* ]] && continue
            [[ -n ${seen[$hash]:-} ]] && continue
            seen[$hash]=1
            sh_url="${base_url}/${path}"
            printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$hash" "$sh_url" "$name" "$archs" "$versions" "$desc"
        done <<< "$index_content"
    done < "$REPOS_FILE" > "$DB_FILE"
}

main "$@"
