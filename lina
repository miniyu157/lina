#!/usr/bin/env bash

# shellcheck shell=bash
# shellcheck disable=SC2155
# shellcheck disable=SC2154

# -- init_ui() --
# @ui _hl1=33m _hl2=32m _hl3=31m _b=1m _off=0m _faint=2m _noint=22m _re=36;7m _rev=7m _off_rev=27m _url=38;5;243m
# @off

set -euo pipefail
shopt -s inherit_errexit 2> /dev/null || true

SELF_PATH=$(realpath "${BASH_SOURCE[0]}") SELF="${SELF_PATH##*/}"
SELF_DIR="${SELF_PATH%/*}" SELF_DIR="${SELF_DIR:-/}"

init_files() {
    export LINA_WORKER_DIR="$LINA_ROOT/data"
    export LINA_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/lina"
    export LINA_REPOS_FILE="${LINA_CONFIG_DIR}/repos"
    export LINA_DB_FILE="${LINA_CONFIG_DIR:?}/local_index.json"

    mkdir -p "$LINA_WORKER_DIR" "$LINA_CONFIG_DIR"
    [[ -e $LINA_REPOS_FILE ]] || touch "$LINA_REPOS_FILE"
    [[ -e $LINA_DB_FILE ]] || touch "$LINA_DB_FILE"
}

init_ui() {
    local line pair key val ansi_header=$'\e[' color_on=1
    [[ ! -t 1 && -z ${FORCE_COLOR:-} ]] && color_on=0
    while read -r line; do
        [[ $line == "# @off"* ]] && return
        [[ $line == "# @ui "* ]] && for pair in ${line#\# @ui }; do
            key="${pair%%=*}" val="${pair#*=}"
            if ((color_on)); then
                declare -gx "${key}=${ansi_header}${val}"
            else
                declare -gx "${key}="
            fi
        done
    done < "$SELF_PATH"
}

check_update() {
    [[ -f "$LINA_ROOT/.lina-dev" ]] || {
        if [[ -s "$LINA_ROOT/update.lock" ]]; then
            echo "$SELF 上次启动时进行了更新, 更新内容是:"
            cat "$LINA_ROOT/update.lock"
            echo ""
        fi
        rm -f "$LINA_ROOT/update.lock"
        (bash "$LINA_ROOT/repo-update" --repo "$LINA_ROOT" --output "$LINA_ROOT/update.lock" -f > /dev/null 2>&1 &)
    }
}

banner() {
    # shellcheck disable=SC2016
    printf '%b' '  \e[2m.---.    \e[33;22;1m.-./`) \e[0m\e[2m,---.   .--.   ____     \e[0m\n' \
        '  \e[2m| \e[33;22;1m,_\e[0m\e[2m|    \e[33;22;1m\\ \e[32m.-.\e[33m'\'')\e[0m\e[2m|    \\  |  | .'\''  __ `.  \e[0m\n' \
        '\e[33;1m,-./  )    / \e[32m`-'\'' \e[33m\\\e[0m\e[2m|  ,  \\ |  |/   '\''  \\  \\ \e[0m\n' \
        '\e[33;1m\\  '\''\e[32m_ \e[33m'\''`)   `-'\''`-`\e[0m\e[2m|  |\\\e[33;22;1m_ \e[0m\e[2m\\|  ||___|  /  | \e[0m\n' \
        ' \e[33;1m> \e[32m(_)  \e[33m)   \e[0m\e[2m.---. |  \e[33;22;1m_( )_\e[0m\e[2m\\  |   _.-`   | \e[0m\n' \
        '\e[33;1m(  .  .-'\''   \e[0m\e[2m|   | | \e[33;22;1m(_ \e[32mo \e[33m_)  \e[0m\e[2m|.'\''   \e[33;22;1m_    \e[0m\e[2m| \e[0m\n' \
        ' \e[33;1m`-'\''`-'\''\e[0m\e[2m|___ |   | |  \e[33;22;1m(_,_)\e[0m\e[2m\\  ||  \e[33;22;1m_( )_  \e[0m\e[2m| \e[0m\n' \
        '  \e[2m|        \\|   | |  |    |  |\\ \e[33;22;1m(_ \e[32mo \e[33m_) \e[0m\e[2m/ \e[0m\n' \
        '  \e[2m`--------`'\''---'\'' '\''--'\''    '\''--'\'' '\''.\e[33;22;1m(_,_)\e[0m\e[2m.'\''  \e[0m\n' \
        '                                          \n'
}

summary_extract() {
    awk '
        /^##$/ {
            if (!state) { state = 1; next }
            exit
        }
        state {
            sub(/^# /, "")
            print
        }
    ' "$1"
}

module_usage() {
    local mod_path="$1"
    local mod_name="${mod_path##*/}"
    local mod_summary=""
    [[ -f "$mod_path/_summary" ]] && mod_summary=$(head -n1 "$mod_path/_summary")

    printf '%b' "${_b}模块 ${_hl2}${mod_name}${_off}: ${mod_summary}\n\n"
    printf '%b' "${_b}用法: ${LINA_PREFIX} <指令> [参数...]${_off}\n"
    printf '%b' "${_b}指令:${_off}\n"

    local sub sub_name sub_summary
    for sub in "$mod_path"/*; do
        [[ -f $sub && -x $sub ]] || continue
        sub_name="${sub##*/}"
        sub_summary=$(summary_extract "$sub")
        printf "  ${_hl2}%-14s${_off} %s\n" "$sub_name" "$sub_summary"
    done

    exit 0
}

usage() {
    cat << EOF
${SELF} ${_hl1}(${GIT_BRANCH})${_off} ${_faint}${LINA_VERSION}${_off}

${_b}用法: ${SELF} <指令> [参数...]${_off}
${_b}指令:${_off}
EOF

    local item name summary
    for item in "$MODS_DIR"/*; do
        [[ -f $item && -x $item ]] || continue
        name="${item##*/}"
        summary=$(summary_extract "$item")
        printf "  ${_hl2}%-12s${_off} %s\n" "$name" "$summary"
    done

    printf '\n%b' "${_b}模块:${_off}\n"

    local mod_summary sub sub_name sub_summary
    for item in "$MODS_DIR"/*/; do
        [[ -d $item ]] || continue
        name="${item%/}"; name="${name##*/}"
        mod_summary=""
        [[ -f "${item}_summary" ]] && mod_summary=$(head -n1 "${item}_summary")
        printf "  ${_hl2}%-12s${_off} %s\n" "$name" "$mod_summary"

        for sub in "$item"*; do
            [[ -f $sub && -x $sub ]] || continue
            sub_name="${sub##*/}"
            sub_summary=$(summary_extract "$sub")
            printf "    ${_hl1}%-12s${_off} %s\n" "$sub_name" "$sub_summary"
        done
    done

    exit "${1:-0}"
}

dispatch() {
    [[ -z ${1:-} ]] && {
        banner
        usage 0
    }

    local mod="$1"
    local mod_cmd="${2:-}"
    local path="$MODS_DIR/$mod"

    [[ $mod == "-h" || $mod == "--help" ]] && usage 0

    [[ -e $path ]] || {
        printf "%b" "${mod} 不是一个有效的 ${SELF} 指令, 请运行 ${_hl2}${SELF} --help${_off} 查看可用指令。\n" >&2
        exit 1
    }

    if [[ -f $path && -x $path ]]; then
        export LINA_PREFIX="$SELF"
        export LINA_CMD="$SELF $mod"

        shift 1
        exec "$path" "$@"
    fi

    if [[ -d $path ]]; then
        export LINA_PREFIX="$SELF $mod"
        export LINA_CMD="$SELF $mod $mod_cmd"

        [[ $mod_cmd == "-h" || $mod_cmd == "--help" ]] && module_usage "$path"

        if [[ -z $mod_cmd ]]; then
            printf "%b" "模块 ${mod} 需要一个指令, 请运行 ${_hl2}${LINA_PREFIX} --help${_off} 查看可用指令。\n" >&2
            exit 1
        fi

        local mod_cmd_path="$path/$mod_cmd"

        [[ -f $mod_cmd_path && -x $mod_cmd_path ]] || {
            printf "%b" "$mod_cmd 不是模块 ${mod} 的指令, 请运行 ${_hl2}${LINA_PREFIX} --help${_off} 查看可用指令。\n" >&2
            exit 1
        }

        shift 2
        exec "$mod_cmd_path" "$@"

    fi
}

main() {
    export LINA_ROOT="${SELF_DIR}"
    export LINA_VERSION="r$(git -C "$LINA_ROOT" rev-list --count HEAD)-$(git -C "$LINA_ROOT" rev-parse --short HEAD)"
    export LINA_DISTROS_REPO_VERSION="v3.1"
    export GIT_BRANCH="$(git -C "$LINA_ROOT" rev-parse --abbrev-ref HEAD)"
    export MODS_DIR="$LINA_ROOT/cells"

    init_files
    init_ui
    check_update
    dispatch "$@"
}

main "$@"
